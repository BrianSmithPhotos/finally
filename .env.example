# FinAlly environment variables (PLAN.md §5).
# Copy to `.env` and fill in. Never commit your real .env.
#   cp .env.example .env

# Required for the AI chat assistant. Get a key at https://openrouter.ai
# Without it, chat endpoints will fail (unless LLM_MOCK=true below).
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) API key for REAL market data.
# Leave empty to use the built-in market simulator (recommended for most users).
MASSIVE_API_KEY=

# Optional: set to "true" for deterministic mock LLM responses (E2E tests / no key).
LLM_MOCK=false
